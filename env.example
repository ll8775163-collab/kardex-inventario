# Copia este archivo a ".env" y cambia los valores antes de desplegar.

# Cadena de conexión a tu base de datos Postgres. En Render, créala como un
# servicio "PostgreSQL" aparte y copia su "Internal Database URL" aquí (o
# configúrala directamente en Render, pestaña Environment de este servicio).
# Formato: postgresql://usuario:password@host:puerto/nombre_basededatos
DATABASE_URL=postgresql://usuario:password@localhost:5432/kardex

# Secreto para firmar los JWT. Genera uno largo y aleatorio, por ejemplo con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_valor_aleatorio_y_largo

# Puerto en el que corre el servidor
PORT=3000

# Costo del hash de bcrypt (10-12 es un buen balance seguridad/velocidad)
BCRYPT_SALT_ROUNDS=12
